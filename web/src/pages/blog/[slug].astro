---
import { getCollection, render, type CollectionEntry } from 'astro:content';

import SiteFooter from '../../components/SiteFooter.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SponsorCTA from '../../components/SponsorCTA.astro';
import { siteConfig } from '../../config/site';
import Layout from '../../layouts/Layout.astro';
import { blogCategoryLabels, isPublishedBlogEntry } from '../../lib/blog';
import { buildBlogPostStructuredData } from '../../lib/seo';

export async function getStaticPaths() {
	const posts = (await getCollection('blog')).filter(isPublishedBlogEntry);
	return posts.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

interface Props {
	entry: CollectionEntry<'blog'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { data } = entry;
const structuredData = buildBlogPostStructuredData(data, siteConfig, Astro.url.pathname);
const published = data.pubDate.toISOString().slice(0, 10);
---

<Layout
	title={data.title}
	description={data.description}
	ogType="article"
	structuredData={structuredData}
	structuredDataSchema="blog-post"
>
	<SiteHeader slot="header" />

	<article class="section-pad">
		<div class="site-container article-shell">
			<a class="back-link" href="/blog/">← Back to blog</a>
			<p class="utility-label">{blogCategoryLabels[data.category]}</p>
			<h1>{data.title}</h1>
			<p class="byline">
				<span>{data.author}</span>
				<time datetime={data.pubDate.toISOString()}>{published}</time>
			</p>
			<div class="entry-content"><Content /></div>
		</div>
	</article>

	<SponsorCTA />
	<SiteFooter slot="footer" />
</Layout>

<style>
	.article-shell {
		max-width: 42rem;
	}

	.back-link {
		color: var(--color-cobalt-strong);
		font-size: var(--text-sm);
		font-weight: 700;
	}

	.utility-label {
		margin-top: 1.5rem;
	}

	h1 {
		margin-top: 0.6rem;
		font-size: var(--text-display);
	}

	.byline {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem 1rem;
		margin-top: 1rem;
		color: var(--color-muted);
		font-family: var(--font-mono);
		font-size: var(--text-sm);
	}

	.entry-content {
		margin-top: 2.5rem;
		color: var(--color-muted);
		font-size: var(--text-lead);
	}

	.entry-content :global(p + p) {
		margin-top: 1rem;
	}

	.entry-content :global(h2),
	.entry-content :global(h3) {
		margin-top: 2rem;
		color: var(--color-ink);
	}
</style>
