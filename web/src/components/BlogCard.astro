---
import type { CollectionEntry } from 'astro:content';

import { blogCategoryLabels } from '../lib/blog';

interface Props {
	entry: CollectionEntry<'blog'>;
}

const { entry } = Astro.props;
const { data } = entry;
const published = data.pubDate.toISOString().slice(0, 10);
---

<article class="blog-card">
	<div class="card-meta">
		<span class="category">{blogCategoryLabels[data.category]}</span>
		<time datetime={data.pubDate.toISOString()}>{published}</time>
	</div>
	<h2><a href={`/blog/${entry.id}/`}>{data.title}</a></h2>
	<p>{data.description}</p>
</article>

<style>
	.blog-card {
		display: grid;
		gap: 0.85rem;
		padding: clamp(1.25rem, 1rem + 1vw, 1.8rem);
		border: 1px solid var(--color-line);
		border-radius: var(--radius-panel);
		background: var(--color-panel);
	}

	.card-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem 1rem;
		color: var(--color-muted);
		font-size: 0.92rem;
	}

	.category {
		color: var(--color-cobalt);
		font-weight: 600;
	}

	h2 {
		margin: 0;
		font-family: var(--font-display);
		font-size: clamp(1.2rem, 1rem + 0.6vw, 1.55rem);
		line-height: 1.25;
	}

	h2 a {
		color: inherit;
		text-decoration: none;
	}

	h2 a:hover {
		color: var(--color-cobalt);
	}

	p {
		margin: 0;
		color: var(--color-muted);
		line-height: 1.6;
	}
</style>
